# 이 파일은 필요한 환경변수의 "목록"입니다 (값은 비워둠, git에 커밋 OK).
# 실제 값은 .env.local 에 넣으세요 (.env.local 은 git 제외됨).

# --- Gemini (서버 전용) ---
GEMINI_API_KEY=

# --- Firebase 클라이언트 (NEXT_PUBLIC_ 접두사 = 브라우저 노출됨, 정상) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin (서버 전용, 절대 NEXT_PUBLIC 금지) ---
# 서비스계정 JSON 전체를 한 줄 문자열로 넣거나, 파일 경로 방식 중 택1 (추후 확정)
FIREBASE_SERVICE_ACCOUNT_KEY=

# --- 미리보기 프로세스 격리 (프로덕션 필수) ---
# 생성 코드 미리보기를 "다른 오리진"에서 실행해 무한루프가 메인 탭을 얼리지 못하게 막는 장치.
# 로컬은 localhost↔127.0.0.1 스왑으로 자동 처리되지만, 배포 시엔 별도 미리보기 도메인을 지정해야 함.
# 미설정 시 미리보기가 같은 오리진에서 돌아 프로세스 격리가 "조용히" 깨짐(콘솔 경고만).
# 예: https://preview.your-domain.com
NEXT_PUBLIC_PREVIEW_ORIGIN=

# --- Cron 보호 (배포 시 필수) ---
# 만료된 previews 정리 cron(/api/cron/cleanup-previews)을 보호하는 시크릿.
# Vercel Cron은 이 값을 Authorization: Bearer 헤더로 자동 전송. 길고 랜덤한 문자열로.
# 미설정 시 cron 라우트는 500으로 거부(우발적 무방비 노출 방지).
CRON_SECRET=

# --- App Check (reCAPTCHA v3) ---
# 사이트 키(공개, NEXT_PUBLIC OK). 미설정 시 코드 하드코딩 폴백 사용. 프로덕션 브라우저에서만 App Check 활성.
NEXT_PUBLIC_APPCHECK_RECAPTCHA_KEY=
# 로컬 dev 브라우저용 디버그 토큰(App Check 콘솔에서 발급). dev 전용 — 프로덕션엔 넣지 말 것.
NEXT_PUBLIC_APPCHECK_DEBUG_TOKEN=

# --- 생성 쿼터/레이트리밋 튜닝 (선택 — 모두 폴백 있어 미설정 시 크래시 없음) ---
# 일반 사용자 일일 생성 상한(기본 30). config 문서/per-user override로도 조정 가능.
GEN_DAILY_LIMIT=
# 교사·admin 일일 생성 상한(기본 100).
ROLE_GEN_DAILY_LIMIT=
# uid별 생성 시작 레이트리밋 — 10분 창당 최대 시작 횟수(기본 30). abort-파밍/DoS 상한.
GEN_RATE_MAX=
