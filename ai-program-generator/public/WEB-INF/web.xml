<?xml version="1.0" encoding="UTF-8"?>
<!--
  ⚠️ [보안 교육/시연용 가짜 허니팟] — 전부 허구. 실제 시스템·DB·자격증명이 아님.
  "leaked web.xml → 노출 DB 콘솔 → Tomcat인 척" 취약점 시연 체인의 1단계.
  Next.js public/ 정적 서빙이라 /WEB-INF/web.xml 로 그대로 노출됨(진짜 WAS면 이게 정보유출 취약점).
  ❗시연 끝나면 이 파일 + app/internal/db-console 삭제할 것. 프로덕션(main)에 배포 금지.
-->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
  <display-name>corp-legacy-portal</display-name>

  <!-- 레거시 컨테이너 데이터소스(마이그레이션 전 임시 설정) -->
  <resource-ref>
    <description>Primary production database</description>
    <res-ref-name>jdbc/prodDB</res-ref-name>
    <res-type>javax.sql.DataSource</res-type>
    <res-auth>Container</res-auth>
  </resource-ref>

  <context-param>
    <param-name>db.connection.url</param-name>
    <param-value>jdbc:mysql://10.10.30.12:3306/prod_portal?useSSL=false&amp;allowPublicKeyRetrieval=true</param-value>
  </context-param>
  <context-param>
    <param-name>db.username</param-name>
    <param-value>portal_admin</param-value>
  </context-param>
  <context-param>
    <param-name>db.password</param-name>
    <param-value>Spr!ng2019$db</param-value>
  </context-param>

  <!-- 내부 관리자 DB 콘솔(방화벽 뒤에 있다고 가정된 것이 실수로 외부 노출) -->
  <context-param>
    <param-name>internal.db.console.path</param-name>
    <param-value>/internal/db-console</param-value>
  </context-param>
</web-app>
